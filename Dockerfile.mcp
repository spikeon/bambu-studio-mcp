# MCP server (Node) + Docker CLI so it can spawn the slicer image via the host socket.
# Build: docker build -f Dockerfile.mcp -t bambu-studio-mcp:mcp .
# Run (from Cursor): docker run -i --rm -v /var/run/docker.sock:/var/run/docker.sock …

FROM node:22-bookworm-slim AS builder
WORKDIR /src
COPY package.json package-lock.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:22-bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends docker.io ca-certificates \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev
COPY --from=builder /src/dist ./dist

# Match published slicer image (override at build with --build-arg SLICER_IMAGE=…)
ARG SLICER_IMAGE=ghcr.io/spikeon/bambu-studio-mcp:latest
ENV BAMBU_STUDIO_IMAGE=${SLICER_IMAGE}

ENTRYPOINT ["node", "dist/index.js"]
